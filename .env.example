# ─────────────────────────────────────────────────────────────
# Masnir Blog — environment variables
# Copy to `.env.local` for local dev. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, RSS, OG.
NEXT_PUBLIC_SITE_URL=https://blog.masnir.site

# ── Newsletter (Phase 2 — provider-agnostic, server-side only) ──
# Example for Buttondown / Resend / Mailchimp. Leave blank to keep the form as UI-only.
NEWSLETTER_PROVIDER=
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# ── Contact form (Phase 2, server-side only) ──
CONTACT_EMAIL_TO=
RESEND_API_KEY=

# ── Comments (disabled initially; architecture ready) ──
# e.g. giscus repo/category ids when enabled
NEXT_PUBLIC_COMMENTS_ENABLED=false
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
